{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "assets/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "dashboard/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/(assets|admin|dashboard|readme-images)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/(.*).php",
      "dest": "/$1.php"
    },
    {
      "src": "/(.*).html",
      "dest": "/$1.html"
    },
    {
      "src": "/",
      "dest": "/index.php"
    }
  ]
}
