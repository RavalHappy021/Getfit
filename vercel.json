{
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.1"
    },
    {
      "src": "assets/images/**",
      "use": "@vercel/static"
    },
    {
      "src": "assets/css/**",
      "use": "@vercel/static"
    },
    {
      "src": "assets/js/**",
      "use": "@vercel/static"
    },
    {
      "src": "admin/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
